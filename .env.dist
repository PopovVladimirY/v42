# V.42 Environment -- Distribution Template
# Copy to .env and fill in all secrets before running docker compose.
#
# DO NOT commit .env to git. It is in .gitignore.

# ----------------------------------------------------------------
# Server
# ----------------------------------------------------------------
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# ----------------------------------------------------------------
# Database
# ----------------------------------------------------------------
# In Docker: DB_HOST must be "postgres" (the container name).
# For local dev with postgres running natively: use "localhost".
DB_HOST=postgres
DB_PORT=5432
DB_NAME=v42
DB_USER=v42
DB_SSL_MODE=disable

# CHANGE THIS: use a strong random password
DB_PASSWORD=CHANGE_ME_strong_db_password

# ----------------------------------------------------------------
# Auth
# ----------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----------------------------------------------------------------
# Application
# ----------------------------------------------------------------
APP_ENV=production
LOG_LEVEL=info

# ----------------------------------------------------------------
# Bootstrap admin account
# Created on first startup if the email does not exist.
# In production mode the admin MUST change password on first login.
# Set SEED_ADMIN_PASSWORD to anything (except "changeme").
# The admin will be forced to change it on first login.
# Leave both blank to skip seeding (not recommended for fresh installs).
# ----------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_temporary_admin_password

# ----------------------------------------------------------------
# CORS: comma-separated list of allowed origins
# Set to your public domain, e.g. https://v42.example.com
# In Docker with nginx on port 80: http://localhost is fine for local.
# ----------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8042

# ----------------------------------------------------------------
# Frontend port (nginx) -- non-standard to avoid conflicts
# ----------------------------------------------------------------
FRONTEND_PORT=8042
